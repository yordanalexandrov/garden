# Gardening Helper — Environment Example
#
# Do not commit real secrets.
# Production deployment target: Hetzner VPS + Docker Compose.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

NODE_ENV=
APP_BASE_URL=
API_BASE_URL=
FRONTEND_URL=

# -----------------------------------------------------------------------------
# Database / Supabase Postgres
# -----------------------------------------------------------------------------

# Self-hosted Supabase Postgres connection details.
# PostgreSQL must be reachable only from the Docker/private network.
# Do not expose the PostgreSQL port publicly.
DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Supabase self-hosted
# -----------------------------------------------------------------------------

# SUPABASE_ANON_KEY is the only Supabase key type that may be exposed to the
# frontend, and only for Supabase Auth login/session handling.
# All application data access still goes through the API.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Backend-only. Never expose the service role key to frontend code, browser
# storage, build output, logs, screenshots, or public docs.
SUPABASE_SERVICE_ROLE_KEY=
# Used by self-hosted Supabase Auth for token signing and by the backend
# AuthPort adapter for JWT validation. Keep one shared value.
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------------------------

SUPABASE_AUTH_EXTERNAL_URL=
SUPABASE_AUTH_SITE_URL=

# -----------------------------------------------------------------------------
# Supabase Storage
# -----------------------------------------------------------------------------

# Problem photos are stored in self-hosted Supabase Storage through StoragePort.
# Clients access files only through signed URLs or protected backend endpoints.
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_BUCKET_PROBLEM_PHOTOS=
PROBLEM_PHOTO_MAX_BYTES=5242880
PROBLEM_PHOTO_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
PROBLEM_PHOTO_SIGNED_URL_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Weather
# -----------------------------------------------------------------------------

WEATHER_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=

# -----------------------------------------------------------------------------
# Push notifications
# -----------------------------------------------------------------------------

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------

# AI provider is accessed behind AiPort.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# -----------------------------------------------------------------------------
# Worker / Scheduler
# -----------------------------------------------------------------------------

# Worker/scheduler runs reminder delivery and weather checks.
WORKER_ENABLED=
REMINDER_JOB_INTERVAL_SECONDS=
WEATHER_JOB_INTERVAL_SECONDS=

# -----------------------------------------------------------------------------
# Supabase Studio / Admin Protection
# -----------------------------------------------------------------------------

# Supabase Studio must not be publicly accessible without protection.
# These credentials are for reverse proxy basic auth or equivalent protection.
# VPN/Tailscale, IP allowlist, or private network access are also acceptable.
SUPABASE_STUDIO_USERNAME=
SUPABASE_STUDIO_PASSWORD=
