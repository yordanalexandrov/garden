# Gardening Helper — Environment Example

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3000

# Self-hosted Supabase Postgres connection string.
# Do not expose this directly to the frontend.
DATABASE_URL=postgres://postgres:postgres@supabase_db:5432/postgres

# Auth
# Auth provider is self-hosted Supabase Auth through AuthPort.
# Frontend may use Supabase Auth public URL/anon key only for login/session.
# All application data access still goes through API_BASE_URL.
AUTH_PROVIDER=supabase
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_ANON_KEY=
# Backend-only; never expose to frontend, browser logs, build output, or public docs.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# CORS
CORS_ORIGIN=http://localhost:4200

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Storage provider is self-hosted Supabase Storage through StoragePort.
STORAGE_PROVIDER=supabase

# Supabase Storage bucket/config
# Problem photos are accessed through backend APIs using signed URLs or protected endpoints.
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Supabase Studio / operations
# -----------------------------------------------------------------------------

# Supabase Studio must not be publicly accessible without protection.
# Use VPN/Tailscale, IP allowlist, reverse proxy basic auth, or private network access.
SUPABASE_STUDIO_HOST=studio.domain.com
SUPABASE_STUDIO_PROTECTION=required

# -----------------------------------------------------------------------------
# Weather
# -----------------------------------------------------------------------------

# Weather provider is Open-Meteo through WeatherPort.
WEATHER_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
WEATHER_DEFAULT_LOCATION_LABEL=Ruse, Bulgaria
WEATHER_DEFAULT_TIMEZONE=Europe/Sofia

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------

# Supported values in early implementation: mock, openai, anthropic, other
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=

# -----------------------------------------------------------------------------
# Push notifications
# -----------------------------------------------------------------------------

# Push provider is raw Web Push with VAPID through PushPort.
PUSH_PROVIDER=web-push

# VAPID keys for Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# Angular dev server should call backend through this base URL.
API_BASE_URL=/api/v1

# Optional frontend public Supabase Auth settings.
# Use these only for login/session handling, never for application table access.
SUPABASE_PUBLIC_URL=
SUPABASE_PUBLIC_ANON_KEY=
