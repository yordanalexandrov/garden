# Gardening Helper — Environment Example

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gardening_helper

# Auth
# For development, the implementation may use a mock/dev auth adapter.
AUTH_PROVIDER=mock
JWT_SECRET=dev-only-change-me

# CORS
CORS_ORIGIN=http://localhost:4200

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Supported values in early implementation: mock, local, s3-compatible, supabase
STORAGE_PROVIDER=mock

# Used by local storage adapter if enabled
STORAGE_LOCAL_DIR=./storage

# Optional future object storage config
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Weather
# -----------------------------------------------------------------------------

# Supported values in early implementation: mock, real-provider-name
WEATHER_PROVIDER=mock
WEATHER_API_KEY=
WEATHER_DEFAULT_LOCATION_LABEL=Ruse, Bulgaria
WEATHER_DEFAULT_TIMEZONE=Europe/Sofia

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------

# Supported values in early implementation: mock, openai, anthropic, other
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=

# -----------------------------------------------------------------------------
# Push notifications
# -----------------------------------------------------------------------------

# Supported values in early implementation: mock, web-push
PUSH_PROVIDER=mock

# VAPID keys for Web Push if real push is enabled
PUSH_PUBLIC_KEY=
PUSH_PRIVATE_KEY=
PUSH_SUBJECT=mailto:admin@example.com

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# Angular dev server should call backend through this base URL.
API_BASE_URL=/api/v1
