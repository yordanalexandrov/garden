# Gardening Helper local Supabase stack
#
# Copy this file to `.env` in this directory before running Docker Compose:
#
#   cp infra/local/.env.example infra/local/.env
#
# Replace every placeholder secret. Do not use these values for production.

COMPOSE_PROJECT_NAME=garden-local

# Public local endpoints
SUPABASE_GATEWAY_PORT=8000
LOCAL_POSTGRES_PORT=54322
SUPABASE_PUBLIC_URL=http://localhost:8000
SUPABASE_AUTH_EXTERNAL_URL=http://localhost:8000/auth/v1
FRONTEND_URL=http://localhost:4200
ADDITIONAL_REDIRECT_URLS=http://localhost:4200

# Database
POSTGRES_DB=postgres
POSTGRES_PASSWORD=replace-with-a-long-local-postgres-password

# Supabase Auth / API keys
# Generate values for these three variables with:
#   node scripts/generate-supabase-jwts.mjs "replace-with-at-least-32-characters"
SUPABASE_JWT_SECRET=replace-with-at-least-32-characters
SUPABASE_ANON_KEY=replace-with-generated-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-generated-service-role-key
JWT_EXPIRY=3600

# Local auth settings
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# PostgREST is present because Supabase Storage uses it internally.
# Do not use this REST API from Angular for Gardening Helper business data.
PGRST_DB_SCHEMAS=storage
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# Storage
SUPABASE_STORAGE_BUCKET_PROBLEM_PHOTOS=problem-photos
STORAGE_TENANT_ID=local
REGION=local
IMGPROXY_AUTO_WEBP=true

# Local SMTP placeholders. Email autoconfirm is enabled above, so these are not
# intended for real mail delivery.
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=localhost
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=Gardening Helper Local
