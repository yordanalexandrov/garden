{
  "name": "gardening-helper-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:db": "vitest run test/db",
    "db:migrate": "tsx src/db/run-migrations.ts",
    "db:reset:test": "tsx src/db/reset-test-database.ts",
    "build": "tsc -p tsconfig.build.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "fastify": "^5.8.5",
    "kysely": "^0.29.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
